comment = 'TierDB: fast, transparent and cost-effective data tiering between Postgres and Apache Iceberg'
default_version = '@CARGO_VERSION@'
module_pathname = '$libdir/tierdb'
relocatable = false
superuser = true
# No `requires = 'pg_duckdb'`: the extension loads standalone (catalog, planning,
# write routing); read execution delegates to pg_duckdb when it is installed.
